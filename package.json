{
  "name": "boardsh",
  "version": "1.0.0",
  "description": "CLI for interacting with The Board API",
  "type": "module",
  "bin": {
    "boardsh": "dist/src/cli.js"
  },
  "exports": {
    ".": "./dist/src/index.js"
  },
  "files": [
    "dist/src",
    "SKILL.md",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist",
    "lint": "tsc -p tsconfig.json --noEmit",
    "pretest": "npm run build",
    "test": "node --test dist/test/**/*.test.js",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "keywords": [
    "boardsh",
    "board",
    "cli",
    "kanban",
    "api"
  ],
  "author": "Kaf",
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "typescript": "^5.9.3"
  }
}
